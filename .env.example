# Hermes server (Vercel env vars)
HERMES_USER_ID=your-auth-user-id-here
HERMES_TRIGGER_SECRET=generate-a-long-random-string

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-key

# Google Gemini (for /now interpretation + /chat)
GOOGLE_AI_API_KEY=AIza...your-key
# Or:
VITE_GOOGLE_AI_API_KEY=AIza...your-key
