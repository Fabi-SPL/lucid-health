<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Lucid Health</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>audio</string>
		<string>location</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.lucid.health.ble-keepalive</string>
		<string>com.lucid.health.ble-overnight</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Lucid Health streams heart rate, HRV, and recovery data from your Whoop strap.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Lucid Health needs Bluetooth to connect to your Whoop strap.</string>
	<key>NSCameraUsageDescription</key>
	<string>Take photos of meals and scan barcodes to log food.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Pick existing meal photos to log.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Lucid Health reads step count to improve illness detection accuracy.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Lucid Health writes recovery and strain scores to Apple Health.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Lucid Health tracks altitude during ski and outdoor sessions.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Lucid Health tracks altitude continuously during outdoor sessions.</string>
</dict>
</plist>
